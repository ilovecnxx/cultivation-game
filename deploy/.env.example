# ============================================
# cultivation-game 环境变量配置
# 复制本文件为 .env 并按需修改
# cp .env.example .env
# ============================================

# ============================================
# 通用
# ============================================
GAME_ENV=development                          # 运行环境: development / staging / production
IMAGE_TAG=latest                              # Docker 镜像标签
COMPOSE_PROJECT_NAME=cultivation-game          # Docker Compose 项目名

# ============================================
# 对外端口 (宿主机映射)
# ============================================
NGINX_HTTP_PORT=80                            # Nginx HTTP 端口
NGINX_HTTPS_PORT=443                          # Nginx HTTPS 端口
GATEWAY_WS_PORT=8080                          # Gateway WebSocket 端口
GATEWAY_HTTP_PORT=8081                        # Gateway HTTP 端口
AUTH_PORT=8082                                # Auth 服务端口
PLAYER_PORT=8083                              # Player 服务端口
CULTIVATION_PORT=8084                         # Cultivation 服务端口
COMBAT_PORT=8085                              # Combat 服务端口
SOCIAL_PORT=8086                              # Social 服务端口
WORLD_PORT=8087                               # World 服务端口

# ============================================
# 数据存储端口
# ============================================
REDIS_PORT=6379                               # Redis 端口
MYSQL_PORT=3306                               # MySQL 端口
MONGO_PORT=27017                              # MongoDB 端口

# ============================================
# MySQL 配置
# ============================================
MYSQL_ROOT_PASSWORD=change_me_root_password   # MySQL root 密码 (生产环境需修改)
MYSQL_USER=game                               # MySQL 应用用户
MYSQL_PASSWORD=change_me_game_password        # MySQL 应用密码 (生产环境需修改)
MYSQL_DATABASE=cultivation_game               # MySQL 数据库名

# ============================================
# MongoDB 配置
# ============================================
MONGO_USER=admin                              # MongoDB 管理员用户
MONGO_PASSWORD=change_me_mongo_password       # MongoDB 管理员密码 (生产环境需修改)
MONGO_DATABASE=cultivation_game               # MongoDB 数据库名

# ============================================
# Redis 配置
# ============================================
# Redis 无需额外认证配置 (默认通过网络隔离)
# 生产环境建议启用密码: --requirepass <password>

# ============================================
# JWT / 安全
# ============================================
JWT_SECRET=change_me_jwt_secret_key_here      # JWT 签名密钥 (生产环境需修改为长随机字符串)

# ============================================
# 数据库连接
# ============================================
# Auth 服务数据库
AUTH_DB_DSN=game:change_me_game_password@tcp(mysql:3306)/cultivation_game?charset=utf8mb4&parseTime=True&loc=Local

# Player 服务数据库
PLAYER_DB_DSN=game:change_me_game_password@tcp(mysql:3306)/cultivation_game?charset=utf8mb4&parseTime=True&loc=Local

# Cultivation 服务数据库
CULTIVATION_DB_DSN=game:change_me_game_password@tcp(mysql:3306)/cultivation_game?charset=utf8mb4&parseTime=True&loc=Local

# Combat 服务数据库
COMBAT_DB_DSN=game:change_me_game_password@tcp(mysql:3306)/cultivation_game?charset=utf8mb4&parseTime=True&loc=Local

# Social 服务数据库
SOCIAL_DB_DSN=game:change_me_game_password@tcp(mysql:3306)/cultivation_game?charset=utf8mb4&parseTime=True&loc=Local

# World 服务数据库
WORLD_DB_DSN=game:change_me_game_password@tcp(mysql:3306)/cultivation_game?charset=utf8mb4&parseTime=True&loc=Local

# ============================================
# 备份配置
# ============================================
BACKUP_DIR=./backups                          # 备份文件存储目录
BACKUP_RETENTION_DAYS=7                       # 备份保留天数

# S3 / OSS 备份存储 (可选)
S3_ENABLED=false                              # 是否启用 S3 备份上传
S3_BUCKET=                                    # S3 存储桶名 (如: cultivation-game-backups)
S3_ENDPOINT=                                  # S3 兼容服务端点 (阿里云OSS: https://oss-cn-hangzhou.aliyuncs.com)
S3_REGION=                                    # S3 区域 (阿里云OSS: oss-cn-hangzhou)
AWS_ACCESS_KEY_ID=                            # AWS Access Key / OSS AccessKeyId
AWS_SECRET_ACCESS_KEY=                        # AWS Secret Key / OSS AccessKeySecret

# ============================================
# 监控 / 告警 (预留)
# ============================================
# SENTRY_DSN=
# GRAFANA_HOST=
# PROMETHEUS_HOST=
