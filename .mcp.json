{
  "mcpServers": {
    "mongodb-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@krazor/mongodb-mcp"
      ],
      "env": {
        "MONGODB_URI": "mongodb://localhost:27017/cultivation"
      }
    },
    "docker-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@hypnosis/docker-mcp-server"
      ],
      "env": {}
    },
    "mysql-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@berthojoris/mcp-mysql-server",
        "mysql://root:root@localhost:3306/cultivation",
        "list,read,utility,create,update,delete"
      ],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
