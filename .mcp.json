{
  "mcpServers": {
    "redis-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis"
      ],
      "env": {}
    },
    "mongodb-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@executeautomation/mongodb-mcp-server"
      ],
      "env": {}
    },
    "docker-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@hypnosis/docker-mcp-server"
      ],
      "env": {}
    },
    "mysql-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@berthojoris/mcp-mysql-server"
      ],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_DATABASE": "cultivation",
        "MYSQL_PASSWORD": "root"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}