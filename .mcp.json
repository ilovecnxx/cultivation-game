{
  "mcpServers": {
    "mongodb-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@krazor/mongodb-mcp"
      ],
      "env": {
        "MONGODB_URI": "mongodb://localhost:27017/cultivation"
      }
    },
    "docker-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@hypnosis/docker-mcp-server"
      ],
      "env": {}
    },
    "mysql-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@berthojoris/mcp-mysql-server"
      ],
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "3306",
        "DB_USER": "root",
        "DB_PASSWORD": "root",
        "DB_NAME": "cultivation"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
